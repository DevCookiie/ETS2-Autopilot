<Window x:Class="ETS2Autopilot.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ETS2 Autopilot" Height="520" Width="420"
        Background="#1a1a2e" Foreground="White"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0f3460"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#c0c0d0"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#e94560"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="ETS2 AUTOPILOT" FontSize="20" FontWeight="Bold"
                       Foreground="#e94560" VerticalAlignment="Center"/>
            <TextBlock x:Name="VersionText" Text=" v1.0" FontSize="12"
                       Foreground="#666" VerticalAlignment="Bottom" Margin="4,0,0,2"/>
        </StackPanel>

        <!-- Connection status -->
        <Border Grid.Row="1" Background="#16213e" BorderBrush="#0f3460"
                BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="10" Height="10"
                         Fill="#444" VerticalAlignment="Center"/>
                <TextBlock x:Name="ConnectionText" Text="Ikke forbundet til ETS2"
                           Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Telemetry display -->
        <Border Grid.Row="2" Background="#16213e" BorderBrush="#0f3460"
                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="HASTIGHED" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="SpeedText" Text="0" FontSize="28" FontWeight="Bold"
                               Foreground="#e94560" HorizontalAlignment="Center"/>
                    <TextBlock Text="km/h" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="HASTIGHEDSGR." FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="SpeedLimitText" Text="--" FontSize="28" FontWeight="Bold"
                               Foreground="#f0a500" HorizontalAlignment="Center"/>
                    <TextBlock Text="km/h" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="GPS AFSTAND" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="NavDistText" Text="--" FontSize="28" FontWeight="Bold"
                               Foreground="#00b4d8" HorizontalAlignment="Center"/>
                    <TextBlock Text="meter" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Settings -->
        <Border Grid.Row="3" Background="#16213e" BorderBrush="#0f3460"
                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="INDSTILLINGER" FontSize="10" Foreground="#666" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Max hastighed:" Padding="0"/>
                    <Slider x:Name="MaxSpeedSlider" Grid.Column="1" Minimum="30" Maximum="130"
                            Value="90" TickFrequency="10" IsSnapToTickEnabled="True"
                            ValueChanged="MaxSpeedSlider_ValueChanged"/>
                    <TextBlock x:Name="MaxSpeedLabel" Grid.Column="2" Text="90"
                               VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#e94560"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Sving-afstand (m):" Padding="0"/>
                    <Slider x:Name="TurnDistSlider" Grid.Column="1" Minimum="100" Maximum="600"
                            Value="300" TickFrequency="50" IsSnapToTickEnabled="True"
                            ValueChanged="TurnDistSlider_ValueChanged"/>
                    <TextBlock x:Name="TurnDistLabel" Grid.Column="2" Text="300"
                               VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#e94560"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <CheckBox x:Name="SpeedLimitCheck" Content="Følg hastighedsgrænse"
                              IsChecked="True" Foreground="#c0c0d0" Margin="0,0,16,0"/>
                    <CheckBox x:Name="LaneKeepingCheck" Content="Lane keeping"
                              IsChecked="True" Foreground="#c0c0d0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status log -->
        <Border Grid.Row="4" Background="#16213e" BorderBrush="#0f3460"
                BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="STATUS" FontSize="10" Foreground="#666" Margin="0,0,0,4"/>
                <TextBlock x:Name="StatusText" Text="Venter på forbindelse..."
                           FontSize="12" Foreground="#c0c0d0" TextWrapping="Wrap"/>
                <ProgressBar x:Name="SteerBar" Height="6" Minimum="-1" Maximum="1"
                             Value="0" Margin="0,8,0,2" Background="#333"
                             Foreground="#e94560"/>
                <TextBlock Text="Styreinput" FontSize="9" Foreground="#555"/>
            </StackPanel>
        </Border>

        <!-- Activate button -->
        <Button x:Name="ActivateButton" Grid.Row="5"
                Content="AKTIVER AUTOPILOT  [F5]"
                FontSize="14" FontWeight="Bold"
                Height="44" Click="ActivateButton_Click"
                IsEnabled="False"/>
    </Grid>
</Window>
