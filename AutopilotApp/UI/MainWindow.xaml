<Window x:Class="ETS2Autopilot.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ETS2 Autopilot" Height="600" Width="440"
        Background="#1a1a2e" Foreground="White"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0f3460"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#c0c0d0"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#e94560"/>
        </Style>
        <Style x:Key="DiagRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="ETS2 AUTOPILOT" FontSize="20" FontWeight="Bold"
                       Foreground="#e94560" VerticalAlignment="Center"/>
            <TextBlock Text=" v1.0" FontSize="12" Foreground="#666"
                       VerticalAlignment="Bottom" Margin="4,0,0,2"/>
        </StackPanel>

        <!-- Connection status -->
        <Border Grid.Row="1" Background="#16213e" BorderBrush="#0f3460"
                BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#444" VerticalAlignment="Center"/>
                <TextBlock x:Name="ConnectionText" Text="Ikke forbundet til ETS2"
                           Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="2" Grid.RowSpan="2" Background="#1a1a2e"
                    BorderBrush="#0f3460" Margin="0,0,0,10">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#16213e"/>
                    <Setter Property="Foreground" Value="#888"/>
                    <Setter Property="BorderBrush" Value="#0f3460"/>
                    <Setter Property="Padding" Value="12,4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1,1,1,0" Padding="{TemplateBinding Padding}"
                                        Margin="0,0,2,0">
                                    <ContentPresenter x:Name="Content" ContentSource="Header"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#0f3460"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- === TAB 1: AUTOPILOT === -->
            <TabItem Header="Autopilot">
                <StackPanel Margin="0,10,0,0">

                    <!-- Speed display -->
                    <Border Background="#16213e" BorderBrush="#0f3460"
                            BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="HASTIGHED" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="SpeedText" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="#e94560" HorizontalAlignment="Center"/>
                                <TextBlock Text="km/h" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="HASTIGHEDSGR." FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="SpeedLimitText" Text="--" FontSize="28" FontWeight="Bold"
                                           Foreground="#f0a500" HorizontalAlignment="Center"/>
                                <TextBlock Text="km/h" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="GPS AFSTAND" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="NavDistText" Text="--" FontSize="28" FontWeight="Bold"
                                           Foreground="#00b4d8" HorizontalAlignment="Center"/>
                                <TextBlock Text="meter" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Settings -->
                    <Border Background="#16213e" BorderBrush="#0f3460"
                            BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="INDSTILLINGER" FontSize="10" Foreground="#666" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="Max hastighed:" Padding="0"/>
                                <Slider x:Name="MaxSpeedSlider" Grid.Column="1" Minimum="30" Maximum="130"
                                        Value="90" TickFrequency="10" IsSnapToTickEnabled="True"
                                        ValueChanged="MaxSpeedSlider_ValueChanged"/>
                                <TextBlock x:Name="MaxSpeedLabel" Grid.Column="2" Text="90"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#e94560"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="Sving-afstand (m):" Padding="0"/>
                                <Slider x:Name="TurnDistSlider" Grid.Column="1" Minimum="100" Maximum="600"
                                        Value="300" TickFrequency="50" IsSnapToTickEnabled="True"
                                        ValueChanged="TurnDistSlider_ValueChanged"/>
                                <TextBlock x:Name="TurnDistLabel" Grid.Column="2" Text="300"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#e94560"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <CheckBox x:Name="SpeedLimitCheck" Content="Følg hastighedsgrænse"
                                          IsChecked="True" Foreground="#c0c0d0" Margin="0,0,16,0"/>
                                <CheckBox x:Name="LaneKeepingCheck" Content="Lane keeping"
                                          IsChecked="True" Foreground="#c0c0d0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Status -->
                    <Border Background="#16213e" BorderBrush="#0f3460"
                            BorderThickness="1" CornerRadius="4" Padding="8">
                        <StackPanel>
                            <TextBlock Text="STATUS" FontSize="10" Foreground="#666" Margin="0,0,0,4"/>
                            <TextBlock x:Name="StatusText" Text="Venter på forbindelse..."
                                       FontSize="12" Foreground="#c0c0d0" TextWrapping="Wrap"/>
                            <ProgressBar x:Name="SteerBar" Height="6" Minimum="-1" Maximum="1"
                                         Value="0" Margin="0,8,0,2" Background="#333" Foreground="#e94560"/>
                            <TextBlock Text="Styreinput" FontSize="9" Foreground="#555"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- === TAB 2: DIAGNOSTIK === -->
            <TabItem Header="Diagnostik">
                <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Forbindelser -->
                        <Border Background="#16213e" BorderBrush="#0f3460"
                                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="FORBINDELSER" FontSize="10" Foreground="#666" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock Text="scs-sdk-plugin:" Foreground="#888"/>
                                    <TextBlock x:Name="DiagPlugin" Grid.Column="1" Text="Tjekker..." Foreground="#888"/>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock Text="vJoy:" Foreground="#888"/>
                                    <TextBlock x:Name="DiagVjoy" Grid.Column="1" Text="Tjekker..." Foreground="#888"/>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock Text="ETS2 kører:" Foreground="#888"/>
                                    <TextBlock x:Name="DiagGame" Grid.Column="1" Text="Tjekker..." Foreground="#888"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Live telemetri -->
                        <Border Background="#16213e" BorderBrush="#0f3460"
                                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="LIVE TELEMETRI" FontSize="10" Foreground="#666" Margin="0,0,0,8"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Hastighed:" Foreground="#888"/>
                                    <TextBlock x:Name="DiagSpeed" Grid.Column="1" Text="--" Foreground="White"/></Grid>
                                <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Gear:" Foreground="#888"/>
                                    <TextBlock x:Name="DiagGear" Grid.Column="1" Text="--" Foreground="White"/></Grid>
                                <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Heading:" Foreground="#888"/>
                                    <TextBlock x:Name="DiagHeading" Grid.Column="1" Text="--" Foreground="White"/></Grid>
                                <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock Text="GPS hastighedsgrænse:" Foreground="#888"/>
                                    <TextBlock x:Name="DiagSpeedLimit" Grid.Column="1" Text="--" Foreground="White"/></Grid>
                                <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock Text="GPS afstand:" Foreground="#888"/>
                                    <TextBlock x:Name="DiagNavDist" Grid.Column="1" Text="--" Foreground="White"/></Grid>
                                <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Styring (bruger):" Foreground="#888"/>
                                    <TextBlock x:Name="DiagSteer" Grid.Column="1" Text="--" Foreground="White"/></Grid>
                                <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Gas:" Foreground="#888"/>
                                    <TextBlock x:Name="DiagThrottle" Grid.Column="1" Text="--" Foreground="White"/></Grid>
                                <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Bremse:" Foreground="#888"/>
                                    <TextBlock x:Name="DiagBrake" Grid.Column="1" Text="--" Foreground="White"/></Grid>
                                <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Spillet sat på pause:" Foreground="#888"/>
                                    <TextBlock x:Name="DiagPaused" Grid.Column="1" Text="--" Foreground="White"/></Grid>
                            </StackPanel>
                        </Border>

                        <!-- vJoy test -->
                        <Border Background="#16213e" BorderBrush="#0f3460"
                                BorderThickness="1" CornerRadius="4" Padding="10">
                            <StackPanel>
                                <TextBlock Text="VJOY TEST" FontSize="10" Foreground="#666" Margin="0,0,0,8"/>
                                <TextBlock Text="Brug disse knapper til at binde vJoy-akser i ETS2's kontrolindstillinger: klik på funktionen i spillet (f.eks. Styring/Speeder/Bremse) og tryk derefter den tilsvarende knap her, mens spillet venter på input."
                                           Foreground="#888" FontSize="11" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <Button x:Name="VjoyTestButton" Content="Send test-styring til vJoy"
                                        Click="VjoyTestButton_Click" Height="32" Margin="0,0,0,6"/>
                                <Button x:Name="VjoyTestThrottleButton" Content="Send test-gas til vJoy"
                                        Click="VjoyTestThrottleButton_Click" Height="32" Margin="0,0,0,6"/>
                                <Button x:Name="VjoyTestBrakeButton" Content="Send test-bremse til vJoy"
                                        Click="VjoyTestBrakeButton_Click" Height="32"/>
                                <TextBlock x:Name="DiagVjoyResult" Text="" Foreground="#888"
                                           FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Activate button -->
        <Button x:Name="ActivateButton" Grid.Row="4"
                Content="AKTIVER AUTOPILOT  [F5]"
                FontSize="14" FontWeight="Bold"
                Height="44" Click="ActivateButton_Click"
                IsEnabled="False"/>
    </Grid>
</Window>
